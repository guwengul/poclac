generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum EvaluatorRole {
  PO
  CL
  AC
}

enum PeriodStatus {
  DRAFT
  SCORING_OPEN
  CALIBRATION
  DISTINCTION
  CLOSED
}

enum TribePeriodStatus {
  PENDING
  ACTIVE
  CLOSED
}

enum EvaluationStatus {
  DRAFT
  SUBMITTED
}

enum DistinctionType {
  TOP10
  TOP20
}

enum DistinctionApprovalStatus {
  PENDING
  APPROVED
  LOCKED
}

enum ConstraintMode {
  M1_FREE
  M2_AVERAGE_CAP
  M3_SCORE_BUDGET
  M4_TOP_QUOTA
  M5_SOFT_GUIDANCE
  M6_NORMALIZATION
}

// ─── Organization ─────────────────────────────────────────────────────────────

model Person {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String
  chapter          String?  // legacy, replaced by functionalAreaId
  functionalAreaId String?
  squadId          String?
  isActive         Boolean  @default(true)
  isAdmin          Boolean  @default(false)
  hasLogin         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  functionalArea        FunctionalArea?       @relation("AreaMembers", fields: [functionalAreaId], references: [id])
  squad                 Squad?                @relation("SquadMembers", fields: [squadId], references: [id])
  tribeLeads            Tribe[]               @relation("TribeLead")
  tribeTechLeads        Tribe[]               @relation("TribeTechLead")
  tribeHRPartners       Tribe[]               @relation("TribeHRPartner")
  squadsAsPO            Squad[]               @relation("SquadPO")
  squadsAsAC            Squad[]               @relation("SquadAC")
  chapterLeadAreas      FunctionalArea[]      @relation("AreaChapterLead")
  squadMemberships      SquadMembership[]
  evaluatorAssignments  EvaluatorAssignment[] @relation("Evaluator")
  evaluateeAssignments  EvaluatorAssignment[] @relation("Evaluatee")
  evaluationsGiven      Evaluation[]          @relation("EvaluatorEvals")
  evaluationsReceived   Evaluation[]          @relation("EvaluateeEvals")
  finalScoresLocked     FinalScore[]          @relation("LockedByTL")
  finalScoresReceived   FinalScore[]          @relation("EvaluateeFinalScore")
  distinctionsReceived  Distinction[]         @relation("DistinctionEvaluatee")
  distinctionsMarked    Distinction[]         @relation("DistinctionMarkedBy")
  distinctionsApproved  Distinction[]         @relation("DistinctionApprovedBy")
  tribePeriodsActivated TribePeriod[]         @relation("TribePeriodActivatedBy")
  auditLogs             AuditLog[]
}

model Tribe {
  id               String   @id @default(cuid())
  name             String
  tribeLeadId      String?
  tribeTechLeadId  String?
  tribeHRPartnerId String?
  createdAt        DateTime @default(now())

  tribeLead       Person?  @relation("TribeLead", fields: [tribeLeadId], references: [id])
  tribeTechLead   Person?  @relation("TribeTechLead", fields: [tribeTechLeadId], references: [id])
  tribeHRPartner  Person?  @relation("TribeHRPartner", fields: [tribeHRPartnerId], references: [id])

  squads          Squad[]
  functionalAreas FunctionalArea[]
  tribePeriods    TribePeriod[]
}

model FunctionalArea {
  id            String  @id @default(cuid())
  name          String
  tribeId       String
  chapterLeadId String?

  tribe       Tribe   @relation(fields: [tribeId], references: [id], onDelete: Cascade)
  chapterLead Person? @relation("AreaChapterLead", fields: [chapterLeadId], references: [id])
  members     Person[] @relation("AreaMembers")

  @@unique([tribeId, name])
}

model Squad {
  id             String   @id @default(cuid())
  name           String
  tribeId        String
  productOwnerId String?
  agileCoachId   String?
  createdAt      DateTime @default(now())

  tribe        Tribe   @relation(fields: [tribeId], references: [id], onDelete: Cascade)
  productOwner Person? @relation("SquadPO", fields: [productOwnerId], references: [id])
  agileCoach   Person? @relation("SquadAC", fields: [agileCoachId], references: [id])

  memberships SquadMembership[]
  members     Person[]          @relation("SquadMembers")
}

model SquadMembership {
  id       String @id @default(cuid())
  personId String
  squadId  String
  periodId String

  person Person @relation(fields: [personId], references: [id])
  squad  Squad  @relation(fields: [squadId], references: [id])
  period Period @relation(fields: [periodId], references: [id])

  @@unique([personId, squadId, periodId])
}

// ─── Period & Configuration ───────────────────────────────────────────────────

model Period {
  id                  String       @id @default(cuid())
  name                String
  status              PeriodStatus @default(DRAFT)
  scoringDeadline     DateTime
  calibrationDeadline DateTime
  startDate           DateTime
  endDate             DateTime
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  squadMemberships     SquadMembership[]
  evaluatorAssignments EvaluatorAssignment[]
  roleCriterionConfigs RoleCriterionConfig[]
  roleWeightConfigs    RoleWeightConfig[]
  scoringConstraints   ScoringConstraintConfig[]
  evaluations          Evaluation[]
  finalScores          FinalScore[]
  distinctions         Distinction[]
  tribePeriods         TribePeriod[]
}

// Per-tribe participation in a global period
model TribePeriod {
  id            String            @id @default(cuid())
  periodId      String
  tribeId       String
  status        TribePeriodStatus @default(PENDING)
  activatedAt   DateTime?
  activatedById String?
  createdAt     DateTime          @default(now())

  period      Period  @relation(fields: [periodId], references: [id])
  tribe       Tribe   @relation(fields: [tribeId], references: [id])
  activatedBy Person? @relation("TribePeriodActivatedBy", fields: [activatedById], references: [id])

  @@unique([periodId, tribeId])
}

// 3 fixed criteria — seeded once
model Criterion {
  id          String  @id @default(cuid())
  code        String  @unique // K1, K2, K3
  name        String
  description String?
  isActive    Boolean @default(true)

  roleCriterionConfigs RoleCriterionConfig[]
  evaluationScores     EvaluationScore[]
}

model RoleCriterionConfig {
  id          String        @id @default(cuid())
  periodId    String
  role        EvaluatorRole
  criterionId String
  isActive    Boolean       @default(true)
  weight      Float

  period    Period    @relation(fields: [periodId], references: [id])
  criterion Criterion @relation(fields: [criterionId], references: [id])

  @@unique([periodId, role, criterionId])
}

model RoleWeightConfig {
  id          String        @id @default(cuid())
  periodId    String
  role        EvaluatorRole
  upperWeight Float

  period Period @relation(fields: [periodId], references: [id])

  @@unique([periodId, role])
}

model ScoringConstraintConfig {
  id                 String         @id @default(cuid())
  periodId           String
  role               EvaluatorRole
  mode               ConstraintMode @default(M1_FREE)
  averageCap         Float?
  targetAverage      Float?
  quotaPercent       Float?
  smallTeamThreshold Int?

  period Period @relation(fields: [periodId], references: [id])

  @@unique([periodId, role])
}

// ─── Assignments & Evaluations ────────────────────────────────────────────────

model EvaluatorAssignment {
  id          String        @id @default(cuid())
  periodId    String
  evaluateeId String
  evaluatorId String
  role        EvaluatorRole
  isOverride  Boolean       @default(false) // true = HR Partner manually overrode auto-assignment

  period    Period @relation(fields: [periodId], references: [id])
  evaluatee Person @relation("Evaluatee", fields: [evaluateeId], references: [id])
  evaluator Person @relation("Evaluator", fields: [evaluatorId], references: [id])

  @@unique([periodId, evaluateeId, role])
}

model Evaluation {
  id          String           @id @default(cuid())
  periodId    String
  evaluateeId String
  evaluatorId String
  role        EvaluatorRole
  status      EvaluationStatus @default(DRAFT)
  submittedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  period    Period            @relation(fields: [periodId], references: [id])
  evaluatee Person            @relation("EvaluateeEvals", fields: [evaluateeId], references: [id])
  evaluator Person            @relation("EvaluatorEvals", fields: [evaluatorId], references: [id])
  scores    EvaluationScore[]

  @@unique([periodId, evaluateeId, role])
}

model EvaluationScore {
  id           String  @id @default(cuid())
  evaluationId String
  criterionId  String
  score        Int
  comment      String?

  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  criterion  Criterion  @relation(fields: [criterionId], references: [id])

  @@unique([evaluationId, criterionId])
}

// ─── Calibration & Final Score ────────────────────────────────────────────────

model FinalScore {
  id            String    @id @default(cuid())
  periodId      String
  evaluateeId   String
  suggestionScore Float?
  finalScore    Float?
  justification String?
  lockedById    String?
  lockedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  period    Period  @relation(fields: [periodId], references: [id])
  evaluatee Person  @relation("EvaluateeFinalScore", fields: [evaluateeId], references: [id])
  lockedBy  Person? @relation("LockedByTL", fields: [lockedById], references: [id])

  @@unique([periodId, evaluateeId])
}

// ─── Distinction ──────────────────────────────────────────────────────────────

model Distinction {
  id             String                    @id @default(cuid())
  periodId       String
  evaluateeId    String
  type           DistinctionType
  approvalStatus DistinctionApprovalStatus @default(PENDING)
  markedById     String?
  approvedById   String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  period     Period  @relation(fields: [periodId], references: [id])
  evaluatee  Person  @relation("DistinctionEvaluatee", fields: [evaluateeId], references: [id])
  markedBy   Person? @relation("DistinctionMarkedBy", fields: [markedById], references: [id])
  approvedBy Person? @relation("DistinctionApprovedBy", fields: [approvedById], references: [id])

  @@unique([periodId, evaluateeId])
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(cuid())
  occurredAt    DateTime @default(now())
  userId        String
  action        String
  entity        String
  entityId      String
  oldValue      Json?
  newValue      Json?
  justification String?

  user Person @relation(fields: [userId], references: [id])
}
